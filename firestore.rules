rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "elmejor15@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Collections
    // ===============================================================

    // Items Catalog
    match /items/{itemId} {
      // Allow read for everyone (to support QR scanning and item selection without auth)
      allow read: if true;
      // Allow write for everyone (to support PIN admins who may not be authenticated)
      allow write: if true;
    }

    // Locations
    match /locations/{locationId} {
      // Allow read for everyone (to support QR scanning without auth)
      allow read: if true;
      // Allow write for everyone (to support PIN admins)
      allow write: if true;
    }

    // Stock Levels
    match /stock/{stockId} {
      // Allow read for everyone
      allow read: if true;
      // Allow write for everyone (to support stock updates by employees)
      allow write: if true; 
    }

    // Transactions Log
    match /transactions/{transactionId} {
      // Allow read for everyone
      allow read: if true;
      // Allow create for everyone (to support transaction logging by employees)
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Employees Directory
    match /employees/{employeeId} {
      // Allow read for everyone (to support PIN login verification)
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
